FROM node:20-alpine AS build
WORKDIR /app

ARG VITE_API_URL
ARG VITE_CLIENTES_API_URL
ARG VITE_PEDIDOS_API_URL
ARG VITE_LOCATIONIQ_API_KEY
ARG VITE_GOOGLE_MAPS_API_KEY
ARG VITE_APP_URL

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_CLIENTES_API_URL=${VITE_CLIENTES_API_URL}
ENV VITE_PEDIDOS_API_URL=${VITE_PEDIDOS_API_URL}
ENV VITE_LOCATIONIQ_API_KEY=${VITE_LOCATIONIQ_API_KEY}
ENV VITE_GOOGLE_MAPS_API_KEY=${VITE_GOOGLE_MAPS_API_KEY}
ENV VITE_APP_URL=${VITE_APP_URL}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
