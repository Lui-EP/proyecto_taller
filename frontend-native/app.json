{
  "expo": {
    "name": "MercadoLocal Native",
    "slug": "mercadolocal-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffaf2"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MercadoLocal usa tu ubicación para ubicar entregas, calcular rutas y compartir el avance del pedido."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffaf2"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
